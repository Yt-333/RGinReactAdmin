# ============================================================
#  如意后台 · 环境变量模板
#  ============================================================
#  使用方法：
#    1. 复制此文件为 .env
#    2. 按需修改下方配置
#    3. 重启 dev server (Vite 热更环境变量需重启)
#
#  ⚠️  .env 文件不会被 git 追踪（已在 .gitignore 中）
#  ============================================================

# ── API 模式 ──
# true  → 使用本地 Mock 数据（开发阶段）
# false → 连接真实后端 API
VITE_USE_MOCK=true

# ── API 服务器地址（useMock=false 时生效） ──
VITE_API_BASE=http://localhost:8080/api

# ── 应用标题（可选，覆盖 app.config.js） ──
# VITE_APP_TITLE=我的管理系统

# ── 默认主题（可选） ──
# VITE_DEFAULT_THEME=light-business
